{
  "name": "narrative-engine",
  "version": "0.1.0",
  "type": "module",
  "description": "Zero-dependency, mathematically deterministic engine for narrative-driven contextual storytelling with Hybrid RAG pipeline",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lab": {
      "import": "./dist/lab/server.js",
      "types": "./dist/lab/server.d.ts"
    }
  },
  "bin": {
    "narrativeengine": "./dist/cli.js"
  },
  "files": [
    "dist",
    "lab"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:cli && npm run build:lab",
    "build:lib": "tsc && tsup",
    "build:cli": "tsup --config tsup.cli.ts",
    "build:lab": "tsup --config tsup.lab.ts",
    "check": "tsc --noEmit",
    "dev": "NODE_ENV=development tsx bin/cli.ts -- lab",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.39",
    "cac": "^6.7.14",
    "concurrently": "^8.2.2",
    "resolve-from": "^5.0.0",
    "rolldown": "^1.0.0-rc.12",
    "tsup": "^8.0.1",
    "typescript": "5.6.3",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "narrative",
    "engine",
    "rag",
    "storytelling",
    "context",
    "hybrid-rag"
  ],
  "author": "",
  "license": "MIT"
}