#!/usr/bin/env bash
# Pre-commit hook — runs fast checks before every commit.
#
# Activated via:  git config core.hooksPath .githooks
#
# Fast checks only (runs in <5s):
#   - Rust: cargo fmt
#   - Python: ruff (lint only — pytest needs maturin develop, too slow)
#   - TypeScript: eslint + vitest
# Slower checks (cargo clippy, mypy, pytest, cargo test) run in CI.
#
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

# File patterns for selective checks
CHANGED_RUST=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.rs$' || true)
CHANGED_PY=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.py$' || true)
CHANGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.ts$' || true)
HAS_RUST=$([ "$CHANGED_RUST" -gt 0 ] && echo 1 || echo 0)
HAS_PY=$([ "$CHANGED_PY" -gt 0 ] && echo 1 || echo 0)
HAS_TS=$([ "$CHANGED_TS" -gt 0 ] && echo 1 || echo 0)

echo "── Pre-commit checks ─────────────────────────"

# ── 0. nap-docgen ─────────────────────────────────────────────
echo "→ cargo run -p nap-docgen..."
cargo run -p nap-docgen

# ── 1. Rust formatting ─────────────────────────────────────────
if [ "$HAS_RUST" -eq 1 ]; then
  echo "→ cargo fmt ($CHANGED_RUST changed .rs files)..."
  cargo fmt --all -- --check
  echo "→ cargo clippy ($CHANGED_RUST changed .rs files)..."
  cargo clippy --workspace --all-targets -- -D warnings
else
  echo "→ cargo fmt — skipped (no Rust changes)"
fi

# ── 2. Python lint ──────────────────────────────────────────────
if [ "$HAS_PY" -eq 1 ]; then
  if command -v ruff &>/dev/null; then
    echo "→ ruff ($CHANGED_PY changed .py files)..."
    ruff check python
  else
    echo "→ ruff — skipped (not installed; run: pip install ruff)"
  fi
else
  echo "→ ruff — skipped (no Python changes)"
fi

# ── 3. TypeScript lint ──────────────────────────────────────────
if [ "$HAS_TS" -eq 1 ]; then
  echo "→ eslint ($CHANGED_TS changed .ts files)..."
  cd "$ROOT_DIR/typescript/narrativeengine"
  npx --yes eslint src tests --ext .ts
  cd "$ROOT_DIR"
else
  echo "→ eslint — skipped (no TypeScript changes)"
fi

# ── 4. TypeScript tests ────────────────────────────────────────
if [ "$HAS_TS" -eq 1 ] || [ "$HAS_RUST" -eq 1 ]; then
  echo "→ vitest..."
  cd "$ROOT_DIR/typescript/narrativeengine"
  npx vitest run
  cd "$ROOT_DIR"
else
  echo "→ vitest — skipped (no Rust or TypeScript changes)"
fi

echo "────────────────────────────────────────────────"
echo "All pre-commit checks passed."
